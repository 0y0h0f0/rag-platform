APP_NAME=Distributed RAG Retrieval Platform
API_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag_platform
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=true

DATA_DIR=./data
UPLOAD_DIR=./data/uploads
LANCEDB_URI=./data/lancedb
LANCEDB_TABLE=chunks

CHUNK_SIZE=600
CHUNK_OVERLAP=100

EMBEDDING_BACKEND=local
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=64

TOP_K_DEFAULT=5
SEARCH_MODE_DEFAULT=vector

# --- LLM Provider ---
# Options: deepseek | api | ollama | ab_test
LLM_PROVIDER=api
LLM_API_KEY=dummy
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=120

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Embedding Provider ---
# Options: legacy (sentence_transformers / local hash) | ollama
EMBEDDING_PROVIDER=legacy

# --- A/B Testing ---
AB_MODEL_A=qwen2.5:7b
AB_MODEL_B=qwen2.5:3b
AB_TRAFFIC_SPLIT=0.8

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# --- OpenTelemetry ---
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=rag-platform
